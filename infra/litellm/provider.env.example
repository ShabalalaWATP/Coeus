# Non-secret route inputs for infra/litellm/model-routes.example.yaml.
# Copy to provider.env only for local use. Never put cloud credentials here.

# AWS Bedrock: include the LiteLLM provider prefix. A base model ID, inference
# profile ID or supported ARN can replace the example value.
AWS_REGION_NAME=eu-west-2
LITELLM_BEDROCK_MODEL=bedrock/<approved-model-or-inference-profile>

# GCP Vertex AI: include the LiteLLM provider prefix. Replace the project and
# model with deployment-owned values. Some models support the global location.
VERTEXAI_PROJECT=replace-with-project-id
VERTEXAI_LOCATION=europe-west2
LITELLM_VERTEX_MODEL=vertex_ai/<approved-model-or-endpoint>
