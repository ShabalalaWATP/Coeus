# Local-only example values. Do not commit real secrets.
COEUS_ENVIRONMENT=local
COEUS_DATABASE_URL=postgresql+asyncpg://coeus:coeus-local@127.0.0.1:5432/coeus
COEUS_ALLOWED_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
# Keep zero unless the API is behind explicitly identified reverse proxies.
COEUS_TRUSTED_PROXY_COUNT=0
COEUS_TRUSTED_PROXY_CIDRS=[]
COEUS_LOG_LEVEL=INFO
COEUS_SESSION_SECRET=
COEUS_CSRF_SECRET=
COEUS_ALLOW_DEV_SEED_USERS=false
# Optional local/test override. Leave commented to use the documented mock credential.
# COEUS_LOCAL_SEED_CREDENTIAL=replace-with-local-only-mock-password
COEUS_GCP_PROJECT_ID=
COEUS_GCP_REGION=europe-west2
COEUS_LLM_PROVIDER=mock
COEUS_PROVIDER_MAX_CONCURRENT=4
COEUS_PROVIDER_MAX_CALLS_PER_WINDOW=120
COEUS_PROVIDER_MAX_CALLS_PER_PRINCIPAL=30
COEUS_PROVIDER_WINDOW_SECONDS=60
COEUS_TICKET_MAX_RETAINED=10000
COEUS_TICKET_MAX_RETAINED_PER_PRINCIPAL=50
COEUS_EMBEDDING_PROVIDER=mock
COEUS_EMBEDDING_MODEL_PATH=.local-data/embedding-models
COEUS_OBJECT_STORAGE_PROVIDER=local
COEUS_LOCAL_OBJECT_STORAGE_PATH=.local-data/objects
# PostgreSQL metadata and this object directory must be backed up or reset together.
COEUS_LOCAL_UPLOAD_MAX_BYTES=50000000
COEUS_UPLOAD_MAX_CONCURRENT=2
COEUS_UPLOAD_MAX_CONCURRENT_PER_USER=1
COEUS_UPLOAD_MAX_INFLIGHT_BYTES=100000000
COEUS_ASSET_TOKEN_SECRET=local-only-asset-token-secret-not-for-deploy
COEUS_PERSISTENCE_PROVIDER=postgres
COEUS_TICKET_PERSISTENCE_MODE=shadow_validate
# Used only if COEUS_PERSISTENCE_PROVIDER=file. Normal local development uses PostgreSQL.
# COEUS_PERSISTENCE_PATH=.local-data/state/coeus-state.json
COEUS_EMAIL_PROVIDER=outbox
COEUS_SMTP_HOST=
COEUS_SMTP_PORT=587
COEUS_SMTP_USERNAME=
COEUS_SMTP_PASSWORD=
COEUS_SMTP_FROM=
COEUS_SMTP_STARTTLS=true
COEUS_SMTP_TIMEOUT_SECONDS=10
COEUS_GCS_PRODUCT_ASSETS_BUCKET=
COEUS_GCS_GENERATED_PREVIEWS_BUCKET=
COEUS_PUBSUB_ENABLED=false
COEUS_PUBSUB_TOPIC_PREFIX=coeus-dev
COEUS_GEMINI_API_KEY=
COEUS_GEMINI_API_MODEL=gemini-2.5-flash
COEUS_GEMINI_EMBEDDING_MODEL=gemini-embedding-001
COEUS_GEMINI_API_TIMEOUT_SECONDS=10
