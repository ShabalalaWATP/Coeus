{
  "ignore": [
    "apps/web/src/lib/api-client/generated/**",
    "apps/web/playwright.config.ts",
    "apps/web/src/**/*.fixtures.ts",
    "apps/web/src/**/*.fixtures.tsx",
    "apps/web/src/**/*-test-fixtures.ts",
    "apps/web/src/**/*-test-fixtures.tsx",
    "apps/web/src/**/requests-test-data.ts",
    "apps/web/src/test/**",
